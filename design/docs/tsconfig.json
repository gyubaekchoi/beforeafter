{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "src",
    ".next/types/**/*.ts",
    "./@types/index.d.ts",
    "data/**/*.js"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
