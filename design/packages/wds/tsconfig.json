{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.react.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "node",
      "./@types/index.d.ts",
      "vitest/globals",
      "@testing-library/jest-dom",
      "vitest-axe/extend-expect"
    ],
    "removeComments": false,
    "outDir": "./dist"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
