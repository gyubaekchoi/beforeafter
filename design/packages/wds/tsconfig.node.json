{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "incremental": true,
    "target": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "sourceMap": true,
    "strict": true,
    "alwaysStrict": true,
    "moduleResolution": "node",
    "module": "CommonJS"
  },
  "include": ["tsdown.config.ts", "scripts"],
  "exclude": ["node_modules"]
}
